<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Peace Token Project</title>
    <!-- Premium Google Typography -->
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Heavenly Cinematic Color Palette */
            --sky-top: #0f172a;
            --sky-bottom: #1e1b4b;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --accent-gradient: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
            --bg-gradient: linear-gradient(180deg, #090d16 0%, #020617 100%);
            --font-serif: 'Playfair Display', serif;
            --font-sans: 'Plus Jakarta Sans', sans-serif;
            --transition-smooth: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            --transition-snappy: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body, html {
            min-height: 100%;
            font-family: var(--font-sans);
            color: var(--text-primary);
            background: var(--bg-gradient);
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        /* Ambient Cosmic Background */
        .ambient-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            overflow: hidden;
            pointer-events: none;
        }

        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(140px);
            opacity: 0.15;
            mix-blend-mode: screen;
        }

        .orb-1 {
            width: 600px;
            height: 600px;
            top: -200px;
            left: -100px;
            background: radial-gradient(circle, #38bdf8 0%, transparent 70%);
            animation: floatOrb1 40s infinite alternate linear;
        }

        .orb-2 {
            width: 700px;
            height: 700px;
            bottom: -200px;
            right: -100px;
            background: radial-gradient(circle, #818cf8 0%, transparent 70%);
            animation: floatOrb2 50s infinite alternate linear;
        }

        @keyframes floatOrb1 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(100px, 80px) scale(1.1); }
        }

        @keyframes floatOrb2 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(-120px, -60px) scale(1.05); }
        }

        /* App Structural Wrapper */
        .wrapper {
            max-width: 740px;
            margin: 0 auto;
            padding: 60px 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            justify-content: center;
        }

        /* Universal Glassmorphism Architecture */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }

        /* Audio Pill Controls */
        .audio-pill {
            padding: 10px 22px;
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-size: 0.78rem;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--transition-snappy);
            margin-bottom: 48px;
        }

        .audio-pill:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }

        .audio-pill:active {
            transform: translateY(0);
        }

        .audio-indicator {
            width: 6px;
            height: 6px;
            background: #10b981;
            border-radius: 50%;
            display: none;
            box-shadow: 0 0 10px #10b981;
        }

        .audio-indicator.playing {
            display: block;
            animation: pulseGlow 2s infinite;
        }

        @keyframes pulseGlow {
            0% { opacity: 0.4; transform: scale(0.9); }
            50% { opacity: 1; transform: scale(1.1); }
            100% { opacity: 0.4; transform: scale(0.9); }
        }

        /* Typography & Header Elements */
        header {
            text-align: center;
            margin-bottom: 40px;
        }

        header h1 {
            font-family: var(--font-serif);
            font-weight: 400;
            font-style: italic;
            font-size: 3.8rem;
            letter-spacing: -0.02em;
            background: linear-gradient(180deg, #ffffff 0%, #cbd5e1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 14px;
        }

        header p {
            font-size: 1rem;
            font-weight: 300;
            color: var(--text-secondary);
            letter-spacing: 0.03em;
        }

        /* Core Novelty Engine Component */
        .token-box {
            border-radius: 32px;
            padding: 56px 40px;
            width: 100%;
            text-align: center;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden;
        }

        /* Luxury Physical Token Coin */
        .coin-wrapper {
            perspective: 1000px;
            width: 150px;
            height: 150px;
            margin: 0 auto 40px auto;
        }

        .coin-graphic {
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.01) 100%);
            border: 1px solid var(--glass-border);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3), inset 0 1px 2px rgba(255,255,255,0.15);
            font-size: 2.8rem;
            position: relative;
            transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
            transform-style: preserve-3d;
        }

        .coin-graphic::after {
            content: '';
            position: absolute; top: 6px; left: 6px; right: 6px; bottom: 6px;
            border: 1px dashed rgba(255,255,255,0.15);
            border-radius: 50%;
            pointer-events: none;
        }

        /* Interactive App Counters */
        .session-counter {
            font-size: 0.75rem;
            color: var(--text-secondary);
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-top: 16px;
        }

        /* Seamless hardware-accelerated animations */
        .spin {
            animation: hyperSpin 1.2s cubic-bezier(0.25, 1, 0.5, 1);
        }

        @keyframes hyperSpin {
            0% { transform: rotateY(0deg) scale(1); }
            30% { transform: rotateY(360deg) scale(1.12); }
            60% { transform: rotateY(720deg) scale(0.95); }
            100% { transform: rotateY(1080deg) scale(1); }
        }

        /* Zero-Layout-Shift Output Frame */
        .message-container {
            min-height: 84px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 40px;
            padding: 0 10px;
        }

        .message-text {
            font-family: var(--font-serif);
            font-style: italic;
            font-size: 1.45rem;
            line-height: 1.6;
            color: var(--text-primary);
            opacity: 1;
            transition: opacity 0.3s ease, transform 0.3s ease;
            transform: translateY(0);
        }

        .message-text.changing {
            opacity: 0;
            transform: translateY(4px);
        }

        /* CTA Interactive Button */
        .btn {
            background: var(--accent-gradient);
            color: #090d16;
            border: none;
            padding: 18px 42px;
            font-size: 0.92rem;
            font-family: var(--font-sans);
            font-weight: 600;
            letter-spacing: 0.02em;
            border-radius: 100px;
            cursor: pointer;
            transition: var(--transition-snappy);
            box-shadow: 0 10px 30px rgba(255, 255, 255, 0.05);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(255, 255, 255, 0.12);
            background: #ffffff;
        }

        .btn:active {
            transform: translateY(-1px);
        }

        /* Responsive Safety & Emergency Grid Layout */
        .support-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            width: 100%;
            margin-top: 24px;
        }

        .support-card {
            border-radius: 20px;
            padding: 28px;
            transition: var(--transition-smooth);
        }

        .support-card h3 {
            font-family: var(--font-serif);
            font-style: italic;
